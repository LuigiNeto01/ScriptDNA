# Database
DATABASE_URL=postgresql+asyncpg://scriptdna:scriptdna@localhost:5432/scriptdna

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# YouTube OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# yt-dlp cookies (opcional, melhora download de videos com restricao de idade/regiao)
# Exporte cookies do YouTube no browser com a extensao "Get cookies.txt LOCALLY"
# e copie o arquivo para o caminho abaixo (montado como volume Docker em /data)
# YTDLP_COOKIES_PATH=/data/cookies.txt

# App
APP_ENV=development
DEBUG=true
MAX_UPLOAD_SIZE_MB=25
